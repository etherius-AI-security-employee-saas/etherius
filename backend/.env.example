APP_NAME=Etherius
ENV=development
ENABLE_API_DOCS=true
ENABLE_DEMO_SEED=false
SEED_COMPANY_DATA_ON_REGISTER=false
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:4173
DATABASE_URL=sqlite:///./etherius.db
SECRET_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_64_CHARS
AGENT_SECRET_KEY=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
AGENT_TOKEN_EXPIRE_HOURS=720
CEO_MASTER_KEY=CHANGE_THIS_CEO_MASTER_KEY_FOR_PRODUCTION
ANTHROPIC_API_KEY=
DEMO_COMPANY_NAME=Etherius Demo
DEMO_ADMIN_EMAIL=admin@etheriusdemo.com
DEMO_ADMIN_PASSWORD=Admin123!
DEMO_SUBSCRIPTION_KEY=ETH-SUB-DEMO-2026-START
